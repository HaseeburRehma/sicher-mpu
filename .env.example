# ---------------------------------------------------------------------------
# Contact form email delivery (app/api/contact)
# Copy this file to ".env.local" and fill in SMTP_PASS.
# Submissions are SENT from SMTP_USER and DELIVERED to CONTACT_TO.
# Do NOT put inline "# comments" after a value — keep comments on their own line.
# ---------------------------------------------------------------------------

# Where all contact-form submissions land
CONTACT_TO=info@sichermpu.de

# Sending mailbox — Google Workspace (Gmail) for info@sichermpu.de.
# SMTP_PASS must be a Google "App Password" (16 chars), created at
# https://myaccount.google.com/apppasswords AFTER enabling 2-Step Verification.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@sichermpu.de
SMTP_PASS=
SMTP_FROM=info@sichermpu.de
