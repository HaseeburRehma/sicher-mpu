# ---------------------------------------------------------------------------
# Contact form email delivery (app/api/contact)
# Copy this file to ".env.local" and fill in the SMTP credentials for the
# sichermpu.de mailbox. All inquiries are delivered to CONTACT_TO.
# ---------------------------------------------------------------------------

# Recipient of all contact-form submissions (defaults to info@sichermpu.de)
CONTACT_TO=info@sichermpu.de

# SMTP server of the sichermpu.de mailbox (e.g. your hosting / Google Workspace)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=info@sichermpu.de
SMTP_PASS=
# Optional: the "From" address shown on outgoing mail (defaults to SMTP_USER)
SMTP_FROM=info@sichermpu.de
